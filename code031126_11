package com.citi.ripcurl.webservicecvr.dao;

import co.elastic.clients.elasticsearch._types.FieldValue;
import co.elastic.clients.elasticsearch._types.Script;
import co.elastic.clients.elasticsearch._types.aggregations.Aggregate;
import co.elastic.clients.elasticsearch._types.aggregations.Aggregation;
import co.elastic.clients.elasticsearch._types.query_dsl.Query;
import com.citi.ripcurl.webservicecvr.entity.nlp.DatasetSearchIndex;
import com.citi.ripcurl.webservicecvr.entity.nlp.DatasetViewCriteria;
import org.springframework.data.domain.Sort;
import org.springframework.data.elasticsearch.client.elc.ElasticsearchAggregations;
import org.springframework.data.elasticsearch.client.elc.NativeQuery;
import org.springframework.data.elasticsearch.client.elc.NativeQueryBuilder;
import org.springframework.data.elasticsearch.core.ElasticsearchOperations;
import org.springframework.data.elasticsearch.core.SearchHit;
import org.springframework.data.elasticsearch.core.SearchHits;
import org.springframework.data.elasticsearch.core.mapping.IndexCoordinates;
import org.springframework.stereotype.Component;

import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.Collections;
import java.util.Iterator;
import java.util.List;
import java.util.Map;
import java.util.Spliterator;
import java.util.Spliterators;
import java.util.function.Consumer;
import java.util.stream.Collectors;
import java.util.stream.Stream;
import java.util.stream.StreamSupport;

@Component
@SuppressWarnings("unused")
public class DatasetSearchIndexDao {

    private static final String DATE_PATTERN = "yyyy-MM-dd";

    private final ElasticsearchOperations esOperations;

    public DatasetSearchIndexDao(ElasticsearchOperations esOperations) {
        this.esOperations = esOperations;
    }

    public Map<String, Object> getMessageStats(DatasetViewCriteria viewCriteria) {
        NativeQueryBuilder queryBuilder = getNativeQueryBuilder(viewCriteria)
                .withAggregation("total_document_scanned",
                        Aggregation.of(a -> a.valueCount(v -> v.field("id"))))
                .withAggregation("min_batch_date",
                        Aggregation.of(a -> a.min(m -> m.field("batch_date"))))
                .withAggregation("max_batch_date",
                        Aggregation.of(a -> a.max(m -> m.field("batch_date"))));

        if (viewCriteria.isClientMessagesOnly()) {
            queryBuilder
                    .withAggregation("total_message_count",
                            Aggregation.of(a -> a.sum(s -> s.script(inlineScript(
                                    "if(doc.containsKey('client_message_seq_num')) doc['client_message_seq_num'].length"
                            )))))
                    .withAggregation("total_labeled_message_count",
                            Aggregation.of(a -> a.sum(s -> s.script(inlineScript(
                                    "if(doc.containsKey('client_message_seq_num')) { HashSet seqSet = new HashSet(doc['client_message_seq_num']); " +
                                            "seqSet.retainAll(doc['labeled_message_seq_num']); return seqSet.size() }"
                            )))));
        } else {
            queryBuilder
                    .withAggregation("total_message_count",
                            Aggregation.of(a -> a.sum(s -> s.script(inlineScript(
                                    "if(doc.containsKey('message_seq_num')) doc['message_seq_num'].length"
                            )))))
                    .withAggregation("total_labeled_message_count",
                            Aggregation.of(a -> a.sum(s -> s.script(inlineScript(
                                    "if(doc.containsKey('labeled_message_seq_num')) doc['labeled_message_seq_num'].length"
                            )))));
        }

        SearchHits<Object> hits = esOperations.search(
                queryBuilder.withMaxResults(0).build(),
                Object.class,
                getIndex(viewCriteria.getDataset())
        );

        if (hits.getAggregations() == null) {
            return Collections.emptyMap();
        }

        ElasticsearchAggregations aggregations = (ElasticsearchAggregations) hits.getAggregations();

        return aggregations.aggregationsAsMap().entrySet().stream()
                .collect(Collectors.toMap(
                        Map.Entry::getKey,
                        e -> extractAggregationValue(e.getValue().aggregation().getAggregate())
                ));
    }

    public Stream<DatasetSearchIndex> getDatasetSearchIndicesByCriteria(
            DatasetViewCriteria viewCriteria,
            String sortByField) {

        List<Sort.Order> sortOrders = Arrays.stream(sortByField.split(","))
                .map(String::trim)
                .filter(s -> !s.isEmpty())
                .map(s -> new Sort.Order(Sort.Direction.ASC, s))
                .collect(Collectors.toList());

        NativeQuery query = getNativeQueryBuilder(viewCriteria)
                .withSort(Sort.by(sortOrders))
                .withTrackTotalHits(false)
                .build();

        return StreamSupport.stream(
                new Spliterators.AbstractSpliterator<>(Long.MAX_VALUE, Spliterator.ORDERED) {
                    private Iterator<SearchHit<DatasetSearchIndex>> searchHitIterator;

                    @Override
                    public boolean tryAdvance(Consumer<? super DatasetSearchIndex> action) {
                        if (searchHitIterator == null) {
                            SearchHits<DatasetSearchIndex> searchHits = esOperations.search(
                                    query,
                                    DatasetSearchIndex.class,
                                    getIndex(viewCriteria.getDataset())
                            );
                            searchHitIterator = searchHits.stream().iterator();
                        }

                        if (!searchHitIterator.hasNext()) {
                            return false;
                        }

                        SearchHit<DatasetSearchIndex> searchHit = searchHitIterator.next();
                        action.accept(searchHit.getContent());

                        if (!searchHitIterator.hasNext()) {
                            searchHitIterator = null;
                            query.setSearchAfter(List.copyOf(searchHit.getSortValues()));
                        }

                        return true;
                    }
                },
                false
        );
    }

    public DatasetSearchIndex save(String dataset, DatasetSearchIndex indexedDataset) {
        return esOperations.save(indexedDataset, getIndex(dataset));
    }

    private static IndexCoordinates getIndex(String dataset) {
        return IndexCoordinates.of("dataset-" + dataset.toLowerCase());
    }

    private NativeQueryBuilder getNativeQueryBuilder(DatasetViewCriteria viewCriteria) {
        List<Query> mustQueries = new ArrayList<>();

        mustQueries.add(Query.of(q -> q.range(r -> r
                .date(d -> d
                        .field("batch_date")
                        .gte(viewCriteria.getStartDate().format(DateTimeFormatter.ofPattern(DATE_PATTERN)))
                        .lte(viewCriteria.getEndDate().format(DateTimeFormatter.ofPattern(DATE_PATTERN)))
                )
        )));

        if (viewCriteria.ispChatMessagesOnly()) {
            mustQueries.add(Query.of(q -> q.match(m -> m
                    .field("flg_is_pchat")
                    .query(viewCriteria.ispChatMessagesOnly())
            )));
        }

        viewCriteria.getFilterParam().forEach((key, values) ->
                mustQueries.add(Query.of(q -> q.terms(t -> t
                        .field(key)
                        .terms(ts -> ts.value(
                                values.stream()
                                        .map(DatasetViewCriteria.FilterParam::getEntityKey)
                                        .distinct()
                                        .map(FieldValue::of)
                                        .collect(Collectors.toList())
                        ))
                )))
        );

        Query finalQuery = Query.of(q -> q.bool(b -> b.must(mustQueries)));
        return NativeQuery.builder().withQuery(finalQuery);
    }

    private Script inlineScript(String source) {
        return Script.of(s -> s.inline(i -> i.source(source)));
    }

    private Object extractAggregationValue(Aggregate aggregate) {
        if (aggregate.isMin()) {
            return aggregate.min().valueAsString();
        }
        if (aggregate.isMax()) {
            return aggregate.max().valueAsString();
        }
        if (aggregate.isSum()) {
            return aggregate.sum().value();
        }
        if (aggregate.isValueCount()) {
            return aggregate.valueCount().value();
        }
        return null;
    }
}
