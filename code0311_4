package com.citi.ripcurl.citinlpdataflow.beservices.dao;

import com.citi.ripcurl.citinlpdataflow.beservices.common.utils.AppUtil;
import com.citi.ripcurl.citinlpdataflow.beservices.dao.models.DatasetSearchIndex;
import com.citi.ripcurl.citinlpdataflow.beservices.dao.models.DatasetViewCriteria;
import co.elastic.clients.elasticsearch._types.FieldValue;
import co.elastic.clients.elasticsearch._types.query_dsl.Query;
import org.springframework.data.domain.Sort;
import org.springframework.data.elasticsearch.client.elc.NativeQuery;
import org.springframework.data.elasticsearch.core.ElasticsearchOperations;
import org.springframework.data.elasticsearch.core.SearchHit;
import org.springframework.data.elasticsearch.core.SearchHits;
import org.springframework.data.elasticsearch.core.document.Document;
import org.springframework.data.elasticsearch.core.index.IndexOperations;
import org.springframework.data.elasticsearch.core.mapping.IndexCoordinates;
import org.springframework.data.elasticsearch.core.query.UpdateQuery;
import org.springframework.data.elasticsearch.core.query.UpdateResponse;

import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.Collection;
import java.util.Collections;
import java.util.HashSet;
import java.util.Iterator;
import java.util.LinkedHashSet;
import java.util.List;
import java.util.Map;
import java.util.Objects;
import java.util.Set;
import java.util.Spliterator;
import java.util.Spliterators;
import java.util.function.Consumer;
import java.util.stream.Collectors;
import java.util.stream.Stream;
import java.util.stream.StreamSupport;

import static com.citi.ripcurl.citinlpdataflow.beservices.common.Constants.*;

@SuppressWarnings("unused")
public class DatasetSearchIndexDao {

    private static final String DATE_PATTERN = "yyyy-MM-dd";

    private final ElasticsearchOperations esOperations;

    public DatasetSearchIndexDao(ElasticsearchOperations esOperations) {
        this.esOperations = esOperations;
    }

    public DatasetSearchIndex getDatasetSearchIndexById(String dataset, String id) {
        return esOperations.get(id, DatasetSearchIndex.class, getIndex(dataset));
    }

    public Stream<DatasetSearchIndex> getDatasetSearchIndicesByIds(String dataset, Collection<String> ids) {
        NativeQuery query = NativeQuery.builder()
                .withQuery(Query.of(q -> q.terms(t -> t
                        .field("id")
                        .terms(ts -> ts.value(
                                ids.stream().distinct().map(FieldValue::of).collect(Collectors.toList())
                        ))
                )))
                .withSort(Sort.by("id"))
                .build();

        return streamResult(dataset, query);
    }

    public Stream<DatasetSearchIndex> getDatasetSearchIndicesByViewCriteria(
            DatasetViewCriteria datasetViewCriteria,
            String sortByField) throws Exception {

        List<Sort.Order> sortOrders = java.util.Arrays.stream(sortByField.split(","))
                .map(s -> new Sort.Order(Sort.Direction.ASC, s))
                .collect(Collectors.toList());

        NativeQuery query = buildViewCriteriaQuery(datasetViewCriteria)
                .withSort(Sort.by(sortOrders))
                .withTrackTotalHits(false)
                .build();

        return streamResult(datasetViewCriteria.getDataset(), query);
    }

    private Stream<DatasetSearchIndex> streamResult(String dataset, NativeQuery query) {
        return StreamSupport.stream(
                new Spliterators.AbstractSpliterator<>(Long.MAX_VALUE, Spliterator.ORDERED) {
                    private Iterator<SearchHit<DatasetSearchIndex>> searchHitIterator;

                    @Override
                    public boolean tryAdvance(Consumer<? super DatasetSearchIndex> action) {
                        if (searchHitIterator == null) {
                            SearchHits<DatasetSearchIndex> searchHits =
                                    esOperations.search(query, DatasetSearchIndex.class, getIndex(dataset));
                            searchHitIterator = searchHits.stream().iterator();
                        }

                        if (!searchHitIterator.hasNext()) {
                            return false;
                        }

                        SearchHit<DatasetSearchIndex> searchHit = searchHitIterator.next();
                        DatasetSearchIndex searchIndex = searchHit.getContent();
                        action.accept(searchIndex);

                        if (!searchHitIterator.hasNext()) {
                            searchHitIterator = null;
                            query.setSearchAfter(List.copyOf(searchHit.getSortValues()));
                        }

                        return true;
                    }
                },
                false
        );
    }

    public boolean isIndexAvailable(String dataset) {
        return esOperations.indexOps(getIndex(dataset)).exists();
    }

    public boolean updateLabeledMessageSequences(String dataset, String id, Iterable<String> sequences) {
        UpdateQuery updateQuery = UpdateQuery.builder(id)
                .withDocument(Document.from(Collections.singletonMap("labeled_message_seq_num", sequences)))
                .build();

        UpdateResponse response = esOperations.update(updateQuery, getIndex(dataset));
        return response.getResult() == UpdateResponse.Result.UPDATED
                || response.getResult() == UpdateResponse.Result.NOOP;
    }

    public void save(String dataset, DatasetSearchIndex datasetSearchIndex) {
        IndexCoordinates indexCoordinates = getIndex(dataset);
        IndexOperations io = esOperations.indexOps(indexCoordinates);

        synchronized (this) {
            if (!io.exists()) {
                io.create(Collections.emptyMap(), io.createMapping(DatasetSearchIndex.class));
            }
        }

        esOperations.save(datasetSearchIndex, indexCoordinates);
    }

    public void save(String dataset, List<DatasetSearchIndex> datasetSearchIndices, boolean overwriteExisting) {
        IndexCoordinates indexCoordinates = getIndex(dataset);
        IndexOperations io = esOperations.indexOps(indexCoordinates);

        synchronized (this) {
            if (!io.exists()) {
                io.create(Collections.emptyMap(), io.createMapping(DatasetSearchIndex.class));
            }
        }

        esOperations.save(
                overwriteExisting
                        ? datasetSearchIndices
                        : AppUtil.asyncMap(datasetSearchIndices,
                                i -> esOperations.exists(i.getId(), indexCoordinates) ? null : i)
                                .stream()
                                .filter(Objects::nonNull)
                                .collect(Collectors.toList()),
                indexCoordinates
        );
    }

    private static IndexCoordinates getIndex(String dataset) {
        return IndexCoordinates.of("dataset-" + dataset.toLowerCase());
    }

    private org.springframework.data.elasticsearch.client.elc.NativeQueryBuilder buildViewCriteriaQuery(
            DatasetViewCriteria viewCriteria) throws Exception {

        List<Query> mustQueries = new ArrayList<>();

        switch (viewCriteria.getPeriod()) {
            case VIEW_PERIOD_1W:
                mustQueries.add(batchDateRangeQuery(
                        LocalDate.now().minusWeeks(1).format(DateTimeFormatter.ofPattern(DATE_PATTERN)),
                        LocalDate.now().format(DateTimeFormatter.ofPattern(DATE_PATTERN))));
                break;

            case VIEW_PERIOD_1M:
                mustQueries.add(batchDateRangeQuery(
                        LocalDate.now().minusMonths(1).format(DateTimeFormatter.ofPattern(DATE_PATTERN)),
                        LocalDate.now().format(DateTimeFormatter.ofPattern(DATE_PATTERN))));
                break;

            case VIEW_PERIOD_3M:
                mustQueries.add(batchDateRangeQuery(
                        LocalDate.now().minusMonths(3).format(DateTimeFormatter.ofPattern(DATE_PATTERN)),
                        LocalDate.now().format(DateTimeFormatter.ofPattern(DATE_PATTERN))));
                break;

            case VIEW_PERIOD_CUSTOM:
                mustQueries.add(batchDateRangeQuery(
                        viewCriteria.getStartDate().format(DateTimeFormatter.ofPattern(DATE_PATTERN)),
                        viewCriteria.getEndDate().format(DateTimeFormatter.ofPattern(DATE_PATTERN))));
                break;

            case VIEW_PERIOD_NO_RANGE:
                break;

            default:
                throw new Exception(String.format("Unknown view period: '%s'", viewCriteria.getPeriod()));
        }

        if (viewCriteria.ispChatMessagesOnly()) {
            mustQueries.add(Query.of(q -> q.match(m -> m
                    .field("flg_is_pchat")
                    .query(true)
            )));
        }

        viewCriteria.getFilterParam().forEach((key, values) -> mustQueries.add(
                Query.of(q -> q.terms(t -> t
                        .field(key)
                        .terms(ts -> ts.value(
                                values.stream()
                                        .map(DatasetViewCriteria.FilterParam::getEntityKey)
                                        .map(FieldValue::of)
                                        .collect(Collectors.toList())
                        ))
                ))
        ));

        Query finalQuery = mustQueries.isEmpty()
                ? Query.of(q -> q.matchAll(ma -> ma))
                : Query.of(q -> q.bool(b -> b.must(mustQueries)));

        return NativeQuery.builder().withQuery(finalQuery);
    }

    private Query batchDateRangeQuery(String gte, String lte) {
        return Query.of(q -> q.range(r -> r
                .date(d -> d
                        .field("batch_date")
                        .gte(gte)
                        .lte(lte)
                )
        ));
    }

    public Stream<String> getMessageIds(DatasetViewCriteria datasetViewCriteria, String sortByField) throws Exception {
        return getDatasetSearchIndicesByViewCriteria(datasetViewCriteria, sortByField).flatMap(si -> {
            Set<String> messageSequenceSet = new LinkedHashSet<>(si.getMessageSeqNum());

            if (datasetViewCriteria.isClientMessagesOnly()) {
                messageSequenceSet = new LinkedHashSet<>(si.getClientMessageSeqNum());
            }

            if (datasetViewCriteria.isLabeledMessagesOnly()) {
                messageSequenceSet.retainAll(new HashSet<>(si.getLabeledMessageSeqNum()));
            }

            return messageSequenceSet.stream()
                    .map(seq -> String.format("%s%s%s", si.getId(), DEFAULT_SEPARATOR, seq));
        });
    }

    public boolean delete(String dataset) {
        return esOperations.indexOps(getIndex(dataset)).delete();
    }
}
