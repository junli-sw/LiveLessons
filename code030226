<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender (only used if explicitly requested) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[%d{yyyyMMdd HH:mm:ss.SSS}][%-5p][%t][%c{1}:%L] %m%n</pattern>
        </encoder>
    </appender>

    <!-- Define FILE appender only if requested -->
    <if>
        <condition>isDefined("logback.appenders") &amp;&amp; property("logback.appenders").contains("FILE")</condition>
        <then>
            <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <file>${LOG_FILE_NAME}</file>

                <rollingPolicy class="ch.qos.logback.core.rolling.FixedWindowRollingPolicy">
                    <!-- FIXED: removed .hlog -->
                    <fileNamePattern>${LOG_FILE_NAME}.%i</fileNamePattern>
                    <minIndex>1</minIndex>
                    <maxIndex>20</maxIndex>
                </rollingPolicy>

                <triggeringPolicy class="ch.qos.logback.core.rolling.SizeBasedTriggeringPolicy">
                    <maxFileSize>100MB</maxFileSize>
                </triggeringPolicy>

                <encoder>
                    <pattern>[%d{yyyyMMdd HH:mm:ss.SSS}][%-5p][%t][%c{1}:%L] %m%n</pattern>
                </encoder>
            </appender>
        </then>
    </if>

    <root level="INFO">

        <!-- Default to CONSOLE if property not set -->
        <if>
            <condition>!isDefined("logback.appenders")</condition>
            <then>
                <appender-ref ref="CONSOLE"/>
            </then>
        </if>

        <!-- Attach FILE if requested -->
        <if>
            <condition>isDefined("logback.appenders") &amp;&amp; property("logback.appenders").contains("FILE")</condition>
            <then>
                <appender-ref ref="FILE"/>
            </then>
        </if>

        <!-- Attach CONSOLE if requested -->
        <if>
            <condition>isDefined("logback.appenders") &amp;&amp; property("logback.appenders").contains("CONSOLE")</condition>
            <then>
                <appender-ref ref="CONSOLE"/>
            </then>
        </if>

    </root>

</configuration>
