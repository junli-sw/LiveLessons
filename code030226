<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ========= Appenders ========= -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[%d{yyyyMMdd HH:mm:ss.SSS}][%-5p][%t][%c{1}:%L] %m%n</pattern>
        </encoder>
    </appender>

    <!-- Define FILE appender only when requested -->
    <condition name="WANT_FILE" class="ch.qos.logback.core.boolex.ExpressionPropertyCondition">
        <expression>isDefined("logback.appenders") &amp;&amp; property("logback.appenders").contains("FILE")</expression>
    </condition>

    <if conditionRef="WANT_FILE">
        <then>
            <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <file>${LOG_FILE_NAME}</file>

                <rollingPolicy class="ch.qos.logback.core.rolling.FixedWindowRollingPolicy">
                    <!-- rolled files: xxx.log.1, xxx.log.2, ... -->
                    <fileNamePattern>${LOG_FILE_NAME}.%i</fileNamePattern>
                    <minIndex>1</minIndex>
                    <maxIndex>20</maxIndex>
                </rollingPolicy>

                <triggeringPolicy class="ch.qos.logback.core.rolling.SizeBasedTriggeringPolicy">
                    <maxFileSize>100MB</maxFileSize>
                </triggeringPolicy>

                <encoder>
                    <pattern>[%d{yyyyMMdd HH:mm:ss.SSS}][%-5p][%t][%c{1}:%L] %m%n</pattern>
                </encoder>
            </appender>
        </then>
    </if>

    <!-- ========= Root selection (ONE root, chosen at top level) ========= -->

    <condition name="HAS_APPENDERS" class="ch.qos.logback.core.boolex.ExpressionPropertyCondition">
        <expression>isDefined("logback.appenders")</expression>
    </condition>

    <condition name="WANT_CONSOLE" class="ch.qos.logback.core.boolex.ExpressionPropertyCondition">
        <expression>isDefined("logback.appenders") &amp;&amp; property("logback.appenders").contains("CONSOLE")</expression>
    </condition>

    <condition name="WANT_BOTH" class="ch.qos.logback.core.boolex.ExpressionPropertyCondition">
        <expression>
            isDefined("logback.appenders")
            &amp;&amp; property("logback.appenders").contains("FILE")
            &amp;&amp; property("logback.appenders").contains("CONSOLE")
        </expression>
    </condition>

    <!-- If property not set -> default CONSOLE -->
    <if conditionRef="HAS_APPENDERS">
        <then>

            <if conditionRef="WANT_BOTH">
                <then>
                    <root level="INFO">
                        <appender-ref ref="FILE"/>
                        <appender-ref ref="CONSOLE"/>
                    </root>
                </then>
                <else>

                    <if conditionRef="WANT_FILE">
                        <then>
                            <root level="INFO">
                                <appender-ref ref="FILE"/>
                            </root>
                        </then>
                        <else>

                            <if conditionRef="WANT_CONSOLE">
                                <then>
                                    <root level="INFO">
                                        <appender-ref ref="CONSOLE"/>
                                    </root>
                                </then>
                                <else>
                                    <!-- Property set but doesn't contain FILE/CONSOLE -->
                                    <root level="INFO">
                                        <appender-ref ref="CONSOLE"/>
                                    </root>
                                </else>
                            </if>

                        </else>
                    </if>

                </else>
            </if>

        </then>
        <else>
            <root level="INFO">
                <appender-ref ref="CONSOLE"/>
            </root>
        </else>
    </if>

</configuration>
