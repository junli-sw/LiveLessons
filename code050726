#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: $0 <logfile1> [logfile2 ...]" >&2
  echo "Example: $0 /opt/cvcommrepo/logs/cvrweb_*.log /opt/cvcommrepo/logs/cvrweb_*.log.gz" >&2
  exit 1
fi

TMP_ALL="$(mktemp)"
TMP_FILTERED="$(mktemp)"
trap 'rm -f "$TMP_ALL" "$TMP_FILTERED"' EXIT

START_TS="$(date -d '7 days ago' '+%Y%m%d %H:%M:%S')"
END_TS="$(date '+%Y%m%d %H:%M:%S')"

echo "Collecting input files..." >&2

FOUND=0
for f in "$@"; do
  if [ ! -e "$f" ]; then
    echo "Skipping missing file: $f" >&2
    continue
  fi
  if [ ! -r "$f" ]; then
    echo "Skipping unreadable file: $f" >&2
    continue
  fi

  FOUND=1
  echo "Adding: $f" >&2

  if [[ "$f" == *.gz ]]; then
    zcat -- "$f" >> "$TMP_ALL"
  else
    cat -- "$f" >> "$TMP_ALL"
  fi
done

if [ "$FOUND" -eq 0 ]; then
  echo "No readable input files found." >&2
  exit 1
fi

TOTAL_LINES="$(wc -l < "$TMP_ALL" | tr -d ' ')"
echo "Total combined lines: $TOTAL_LINES" >&2
echo "Filtering RESP + piwik lines first..." >&2

if command -v pv >/dev/null 2>&1; then
  pv -l -s "$TOTAL_LINES" "$TMP_ALL" \
    | grep ' RESP, ' \
    | grep -i 'piwik' \
    > "$TMP_FILTERED"
else
  grep ' RESP, ' "$TMP_ALL" | grep -i 'piwik' > "$TMP_FILTERED"
fi

FILTERED_LINES="$(wc -l < "$TMP_FILTERED" | tr -d ' ')"
echo "Filtered lines kept: $FILTERED_LINES" >&2

awk -v start_ts="$START_TS" -v end_ts="$END_TS" -v total_lines="$FILTERED_LINES" '
BEGIN {
  FS = ", "
}

function trim(s) {
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
  return s
}

function csv_escape(s,    t) {
  t = s
  gsub(/"/, "\"\"", t)
  return "\"" t "\""
}

function extract_prefix_ts(line,   ts) {
  if (match(line, /^\[[0-9]{8} [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3}\]/)) {
    ts = substr(line, 2, 17)
    return ts
  }
  return ""
}

function extract_api_path(url,   p) {
  p = url
  sub(/^https?:\/\/[^\/]+/, "", p)
  sub(/\?.*$/, "", p)
  return p
}

function add_sample(key, url,   arr, n, i, exists) {
  if (url == "") return

  exists = 0
  n = split(samples[key], arr, " || ")
  for (i = 1; i <= n; i++) {
    if (arr[i] == url) {
      exists = 1
      break
    }
  }

  if (!exists) {
    if (samples[key] == "") {
      samples[key] = url
      sample_count[key] = 1
    } else if (sample_count[key] < 5) {
      samples[key] = samples[key] " || " url
      sample_count[key]++
    }
  }
}

END {
}

{
  if (total_lines > 0 && NR % 100000 == 0) {
    pct = sprintf("%.1f", NR * 100 / total_lines)
    printf("Parsing progress: %d/%d lines (%s%%)\n", NR, total_lines, pct) > "/dev/stderr"
  }

  line_ts = extract_prefix_ts($0)
  if (line_ts == "") next
  if (line_ts < start_ts || line_ts > end_ts) next

  n = split($0, f, ", ")
  if (n < 12) next

  url = trim(f[8])
  code = trim(f[10])

  if (url == "" || code == "") next

  endpoint = extract_api_path(url)
  key = endpoint SUBSEP code

  count[key]++
  add_sample(key, url)
}

END {
  if (total_lines > 0) {
    printf("Parsing progress: %d/%d lines (100%%)\n", NR, total_lines) > "/dev/stderr"
  }

  print "\"API Endpoint\",\"Http Code\",\"Number of Requests\",\"Few 5 sample URLs\""

  for (k in count) {
    split(k, a, SUBSEP)
    endpoint = a[1]
    code = a[2]
    urls = samples[k]
    gsub(/ \|\| /, " ; ", urls)
    print csv_escape(endpoint) "," csv_escape(code) "," csv_escape(count[k]) "," csv_escape(urls)
  }
}
' "$TMP_FILTERED" | sort -t',' -k3,3nr
