#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: $0 <logfile>"
  echo "Example: $0 /opt/cvcommrepo/logs/cvrweb_20260506_23_01_21.log"
  exit 1
fi

LOGFILE="$1"

if [ ! -r "$LOGFILE" ]; then
  echo "Cannot read file: $LOGFILE" >&2
  exit 1
fi

TMP_FILTERED="$(mktemp)"
trap 'rm -f "$TMP_FILTERED"' EXIT

START_TS="$(date -d '7 days ago' '+%Y%m%d %H:%M:%S')"
END_TS="$(date '+%Y%m%d %H:%M:%S')"

echo "Log file: $LOGFILE" >&2
echo "Filtering RESP + piwik lines first..." >&2

TOTAL_LINES="$(wc -l < "$LOGFILE" | tr -d ' ')"

# Show prefilter progress if pv exists, otherwise fall back to grep only
if command -v pv >/dev/null 2>&1; then
  pv -l -s "$TOTAL_LINES" "$LOGFILE" \
    | grep ' RESP, ' \
    | grep -i 'piwik' \
    > "$TMP_FILTERED"
else
  grep ' RESP, ' "$LOGFILE" | grep -i 'piwik' > "$TMP_FILTERED"
fi

FILTERED_LINES="$(wc -l < "$TMP_FILTERED" | tr -d ' ')"
echo "Filtered lines kept: $FILTERED_LINES" >&2

if [ "$FILTERED_LINES" -eq 0 ]; then
  echo "| API Endpoint | Http Code | Number of Requests | Few 5 sample URLs |"
  echo "|---|---:|---:|---|"
  exit 0
fi

awk -v start_ts="$START_TS" -v end_ts="$END_TS" -v total_lines="$FILTERED_LINES" '
BEGIN {
  FS = ", "
}

function trim(s) {
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
  return s
}

function extract_prefix_ts(line,   ts) {
  # from: [20260507 13:04:03.895]
  # to:   20260507 13:04:03
  if (match(line, /^\[[0-9]{8} [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3}\]/)) {
    ts = substr(line, 2, 17)
    return ts
  }
  return ""
}

function extract_api_path(url,   p) {
  p = url
  sub(/^https?:\/\/[^\/]+/, "", p)
  sub(/\?.*$/, "", p)
  return p
}

function add_sample(key, url,   arr, n, i, exists) {
  if (url == "") return

  exists = 0
  n = split(samples[key], arr, " || ")
  for (i = 1; i <= n; i++) {
    if (arr[i] == url) {
      exists = 1
      break
    }
  }

  if (!exists) {
    if (samples[key] == "") {
      samples[key] = url
      sample_count[key] = 1
    } else if (sample_count[key] < 5) {
      samples[key] = samples[key] " || " url
      sample_count[key]++
    }
  }
}

{
  if (NR % 100000 == 0) {
    pct = sprintf("%.1f", NR * 100 / total_lines)
    printf("Parsing progress: %d/%d lines (%s%%)\n", NR, total_lines, pct) > "/dev/stderr"
  }

  line_ts = extract_prefix_ts($0)
  if (line_ts == "") next

  if (line_ts < start_ts || line_ts > end_ts) next

  n = split($0, f, ", ")
  if (n < 12) next

  # RESP format from your Java code:
  # 1  prefix with RESP
  # 2  hostname
  # 3  module
  # 4  port
  # 5  clientId
  # 6  userId
  # 7  reqId
  # 8  fullURL
  # 9  response timestamp
  # 10 http status
  # 11 elapsed time
  # 12 content length

  url = trim(f[8])
  code = trim(f[10])

  if (url == "" || code == "") next

  endpoint = extract_api_path(url)
  key = endpoint SUBSEP code

  count[key]++
  add_sample(key, url)
}

END {
  printf("Parsing progress: %d/%d lines (100%%)\n", NR, total_lines) > "/dev/stderr"

  print "| API Endpoint | Http Code | Number of Requests | Few 5 sample URLs |"
  print "|---|---:|---:|---|"

  for (k in count) {
    split(k, a, SUBSEP)
    endpoint = a[1]
    code = a[2]
    urls = samples[k]
    gsub(/ \|\| /, "<br>", urls)
    print "| " endpoint " | " code " | " count[k] " | " urls " |"
  }
}
' "$TMP_FILTERED" | {
  IFS= read -r h1 || true
  IFS= read -r h2 || true
  printf '%s\n%s\n' "$h1" "$h2"
  sort -t'|' -k4,4nr
}
