#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   ./piwik_stats.sh /path/to/access.log
#   ./piwik_stats.sh /path/to/logdir/*.log
#
# Output:
#   API Endpoint | Http Code | Number of Requests | Few 5 sample URLs

if [ "$#" -lt 1 ]; then
  echo "Usage: $0 <logfile-or-files>"
  exit 1
fi

START_DATE="$(date -d '7 days ago' +%F)"
END_DATE="$(date +%F)"

awk -v start="$START_DATE" -v end="$END_DATE" '
function trim(s) {
  gsub(/^[ \t\r\n]+|[ \t\r\n]+$/, "", s)
  return s
}

function add_sample(key, url,    n, arr, i, exists) {
  if (url == "") return

  exists = 0
  n = split(samples[key], arr, " || ")
  for (i = 1; i <= n; i++) {
    if (arr[i] == url) {
      exists = 1
      break
    }
  }

  if (!exists) {
    if (samples[key] == "") {
      samples[key] = url
      sample_count[key] = 1
    } else if (sample_count[key] < 5) {
      samples[key] = samples[key] " || " url
      sample_count[key]++
    }
  }
}

BEGIN {
  OFS = "\t"
  print "API Endpoint", "Http Code", "Number of Requests", "Few 5 sample URLs"
}

{
  line = $0

  # Keep only lines mentioning Piwik
  if (line !~ /[Pp]iwik/) next

  # Extract YYYY-MM-DD date from line
  line_date = ""
  if (match(line, /[0-9]{4}-[0-9]{2}-[0-9]{2}/)) {
    line_date = substr(line, RSTART, RLENGTH)
  } else {
    next
  }

  # Last 7 days filter
  if (line_date < start || line_date > end) next

  # Extract URL or path
  url = ""
  endpoint = ""

  # Try full URL first
  if (match(line, /(https?:\/\/[^ ,"'\''\t]+)/)) {
    url = substr(line, RSTART, RLENGTH)
  }
  # Otherwise try path-like token
  else if (match(line, /(\/[A-Za-z0-9._~:\/?#\[\]@!$&()*+,;=%-]+)/)) {
    url = substr(line, RSTART, RLENGTH)
  }

  if (url == "") next

  # Normalize endpoint by stripping scheme/host and query string
  endpoint = url
  sub(/^https?:\/\/[^\/]+/, "", endpoint)
  sub(/\?.*$/, "", endpoint)

  # Extract HTTP status code
  code = ""
  if (match(line, /(^|[^0-9])([1-5][0-9][0-9])([^0-9]|$)/, m)) {
    code = m[2]
  } else {
    next
  }

  key = endpoint SUBSEP code
  count[key]++
  add_sample(key, url)
}

END {
  for (k in count) {
    split(k, parts, SUBSEP)
    endpoint = parts[1]
    code = parts[2]
    print endpoint, code, count[k], samples[k]
  }
}
' "$@" | sort -t $'\t' -k3,3nr
