#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: $0 <logfile-or-files>"
  echo "Example: $0 /var/log/app/*.log"
  exit 1
fi

START_EPOCH="$(date -d '7 days ago' +%s)"
NOW_EPOCH="$(date +%s)"

awk -v start_epoch="$START_EPOCH" -v now_epoch="$NOW_EPOCH" '
BEGIN {
  FS = ", "
}

function trim(s) {
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
  return s
}

function line_epoch_from_prefix(line,   s, y, mo, d, h, mi, se, cmd, out) {
  if (match(line, /^\[([0-9]{8}) ([0-9]{2}):([0-9]{2}):([0-9]{2})\.[0-9]{3}\]/)) {
    s = substr(line, RSTART + 1, RLENGTH - 2)
    y  = substr(s, 1, 4)
    mo = substr(s, 5, 2)
    d  = substr(s, 7, 2)
    h  = substr(s, 10, 2)
    mi = substr(s, 13, 2)
    se = substr(s, 16, 2)
    cmd = "date -d \"" y "-" mo "-" d " " h ":" mi ":" se "\" +%s"
    cmd | getline out
    close(cmd)
    return out + 0
  }
  return 0
}

function extract_api_path(url,   p) {
  p = url
  sub(/^https?:\/\/[^\/]+/, "", p)
  sub(/\?.*$/, "", p)
  return p
}

function add_sample(key, url,   arr, n, i, exists) {
  if (url == "") return

  exists = 0
  n = split(samples[key], arr, " || ")
  for (i = 1; i <= n; i++) {
    if (arr[i] == url) {
      exists = 1
      break
    }
  }

  if (!exists) {
    if (samples[key] == "") {
      samples[key] = url
      sample_count[key] = 1
    } else if (sample_count[key] < 5) {
      samples[key] = samples[key] " || " url
      sample_count[key]++
    }
  }
}

{
  epoch = line_epoch_from_prefix($0)
  if (epoch < start_epoch || epoch > now_epoch) next

  if (tolower($0) !~ /piwik/) next
  if ($0 !~ / RESP, /) next

  n = split($0, f, ", ")

  # RESP format from your code:
  # 1  prefix containing RESP
  # 2  hostname
  # 3  module
  # 4  port
  # 5  clientId
  # 6  userId
  # 7  reqId
  # 8  fullURL
  # 9  response timestamp
  # 10 http status
  # 11 elapsed time
  # 12 content length

  if (n < 10) next

  url = trim(f[8])
  code = trim(f[10])

  if (url == "" || code == "") next

  endpoint = extract_api_path(url)
  key = endpoint SUBSEP code

  count[key]++
  add_sample(key, url)
}

END {
  print "| API Endpoint | Http Code | Number of Requests | Few 5 sample URLs |"
  print "|---|---:|---:|---|"

  for (k in count) {
    split(k, a, SUBSEP)
    endpoint = a[1]
    code = a[2]
    urls = samples[k]
    gsub(/\|\|/, "<br>", urls)
    print "| " endpoint " | " code " | " count[k] " | " urls " |"
  }
}
' "$@" | {
  IFS= read -r h1 || true
  IFS= read -r h2 || true
  printf '%s\n%s\n' "$h1" "$h2"
  sort -t'|' -k4,4nr
}
