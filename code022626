4) Build each Object[] args in the exact same order

Make sure entity_info binds are Strings (Oracle NVARCHAR2 expects String). Convert null-safe.

private Object[] buildBatchEntryArgs(
        String cfgName,
        Integer version,
        String userId,
        List<Map.Entry<String, Map<String, Object>>> schemaOrdered,
        Map<String, Object> record) {

    int n = schemaOrdered.size();
    Object[] args = new Object[n + 7];
    int p = 0;

    args[p++] = cfgName;
    args[p++] = version;

    // ENTITY_INFO_1..N
    for (Map.Entry<String, Map<String, Object>> e : schemaOrdered) {
        String fieldName = e.getKey(); // your record uses this key
        Object v = record.get(fieldName);
        args[p++] = (v == null) ? null : String.valueOf(v);
    }

    args[p++] = record.get("reason") == null ? null : String.valueOf(record.get("reason"));
    args[p++] = record.get("status") == null ? null : String.valueOf(record.get("status"));
    args[p++] = userId;

    // WHERE CFG_NAME / VERSION
    args[p++] = cfgName;
    args[p++] = version;

    return args;
}
5) Call batchUpdate
List<Object[]> batchArgs = new ArrayList<>(records.size());
for (Map<String, Object> recordDataMap : records) {
    batchArgs.add(buildBatchEntryArgs(cfgName, version, userId, schemaOrdered, recordDataMap));
