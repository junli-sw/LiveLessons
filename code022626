sql.append("REASON, STATUS, MODIFIED_BY, MODIFIED_TIME) ");

sql.append("SELECT ?, ?, NVL(MAX(ENTRY_SEQ_NUM), 0) + 1, ");
sql.append(String.join(", ", java.util.Collections.nCopies(schemaOrdered.size(), "?")));
sql.append(", ?, ?, ?, sysdate ");
sql.append("FROM CFG_DF_BATCH_CONFIG_ENTRIES WHERE CFG_NAME = ? AND VERSION = ?");
String addBatchEntryQuery = sql.toString();
