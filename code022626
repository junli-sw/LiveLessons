1) Make the entity-info column order deterministic

If batchConfigSchemaMap is a HashMap, order is not guaranteed. Use a stable ordering (recommended: sort by entity_info_seq_num or by key).

private List<Map.Entry<String, Map<String, Object>>> orderedEntityInfoSchema(
        Map<String, Map<String, Object>> batchConfigSchemaMap) {

    return batchConfigSchemaMap.entrySet().stream()
            // if schema has an "entity_info_seq_num" field, sort by it; otherwise sort by key
            .sorted((a, b) -> {
                Object sa = a.getValue().get("entity_info_seq_num");
                Object sb = b.getValue().get("entity_info_seq_num");
                if (sa instanceof Number && sb instanceof Number) {
                    return Integer.compare(((Number) sa).intValue(), ((Number) sb).intValue());
                }
                return a.getKey().compareTo(b.getKey());
            })
            .toList();
}
2) Build SQL using that same order
List<Map.Entry<String, Map<String, Object>>> schemaOrdered = orderedEntityInfoSchema(batchConfigSchemaMap);

StringBuilder sql = new StringBuilder();
sql.append("INSERT INTO CFG_DF_BATCH_CONFIG_ENTRIES(CFG_NAME, VERSION, ENTRY_SEQ_NUM, ");

for (int i = 0; i < schemaOrdered.size(); i++) {
    int seq = i + 1; // ENTITY_INFO_1..N
    sql.append("ENTITY_INFO_").append(seq).append(", ");
